# ── External APIs ──────────────────────────────────────────────────────────

# OpenAI (for AI labeling via Distilabel)
OPENAI_API_KEY=sk-...

# HuggingFace (for model publish)
HF_TOKEN=hf_...
HF_MODEL_REPO=your-org/pika-emotion-model

# Langfuse (Phase 2 — trace extraction)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Docker Infra (docker-compose-infra.yml) ───────────────────────────────

# Shared PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=adminpass
POSTGRES_PORT=5432

# Argilla
ARGILLA_PORT=6900
ARGILLA_USERNAME=admin
ARGILLA_PASSWORD=adminpassword
ARGILLA_API_KEY=argilla.apikey
ARGILLA_API_URL=http://localhost:6900
ARGILLA_REDIS_PORT=6379

# Elasticsearch (Argilla backend)
ELASTICSEARCH_PORT=9200

# MLflow
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000

# MinIO (MLflow artifact store)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
